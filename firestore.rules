rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function requesterDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function requesterProfileExists() {
      return isSignedIn() && requesterDoc().data != null;
    }

    function isAdmin() {
      return requesterProfileExists() && requesterDoc().data.role == 'admin';
    }

    function isSupervisor() {
      return requesterProfileExists() && requesterDoc().data.role == 'supervisor';
    }

    function isClearedStudent() {
      return requesterProfileExists()
        && requesterDoc().data.role == 'student'
        && ("uploadCleared" in requesterDoc().data)
        && requesterDoc().data.uploadCleared == true;
    }

    function isValidRole(role) {
      return role in ['student', 'supervisor', 'admin'];
    }

    function isValidProjectStatus(status) {
      return status in ['approved', 'pending', 'rejected'];
    }

    function hasClearanceShape(data) {
      return data.uploadCleared is bool
      && data.clearedBySupervisorUid is string
      && data.clearedBySupervisorName is string
      && data.clearanceUpdatedAt is string;
    }

    function isValidUserProfile(data, userId) {
      return data.keys().hasOnly([
        'uid',
        'email',
        'fullName',
        'photoURL',
        'department',
        'role',
        'uploadCleared',
        'clearedBySupervisorUid',
        'clearedBySupervisorName',
        'clearanceUpdatedAt',
        'createdAt',
        'updatedAt'
      ])
      && data.uid is string
      && data.uid == userId
      && data.email is string
      && data.email.size() > 3
      && data.fullName is string
      && data.fullName.size() >= 2
      && data.fullName.size() <= 120
      && (!("photoURL" in data) || data.photoURL is string)
      && data.department is string
      && data.department.size() >= 2
      && data.department.size() <= 120
      && data.role is string
      && isValidRole(data.role)
      && (
        (
          !("uploadCleared" in data)
          && !("clearedBySupervisorUid" in data)
          && !("clearedBySupervisorName" in data)
          && !("clearanceUpdatedAt" in data)
        )
        || hasClearanceShape(data)
      )
      && data.createdAt is string
      && data.updatedAt is string;
    }

    function canSupervisorUpdateStudentClearance() {
      return isSupervisor()
      && resource.data.role == 'student'
      && request.resource.data.role == 'student'
      && request.resource.data.uid == resource.data.uid
      && request.resource.data.email == resource.data.email
      && request.resource.data.fullName == resource.data.fullName
      && request.resource.data.department == resource.data.department
      && request.resource.data.photoURL == resource.data.photoURL
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'uploadCleared',
        'clearedBySupervisorUid',
        'clearedBySupervisorName',
        'clearanceUpdatedAt',
        'updatedAt'
      ])
      && (
        (request.resource.data.uploadCleared == true
          && request.resource.data.clearedBySupervisorUid == request.auth.uid
          && request.resource.data.clearedBySupervisorName.size() >= 2)
        || (request.resource.data.uploadCleared == false
          && request.resource.data.clearedBySupervisorUid == ''
          && request.resource.data.clearedBySupervisorName == '')
      );
    }

    function isValidKeywords(keywords) {
      return keywords is list
      && keywords.size() > 0
      && keywords.size() <= 20
      && keywords[0] is string;
    }

    function isValidEmbedding(embedding) {
      return embedding is list
      && embedding.size() > 0
      && embedding.size() <= 4096
      && embedding[0] is number;
    }

    function isValidProjectRecord(data) {
      return data.keys().hasOnly([
        'title',
        'abstract',
        'keywords',
        'department',
        'year',
        'supervisor',
        'studentName',
        'fileUrl',
        'filePublicId',
        'status',
        'embedding',
        'createdAt',
        'updatedAt'
      ])
      && data.title is string
      && data.title.size() >= 5
      && data.title.size() <= 300
      && data.abstract is string
      && data.abstract.size() >= 20
      && data.abstract.size() <= 20000
      && isValidKeywords(data.keywords)
      && data.department is string
      && data.department.size() >= 2
      && data.department.size() <= 120
      && data.year is int
      && data.year >= 2000
      && data.year <= 2100
      && data.supervisor is string
      && data.supervisor.size() >= 2
      && data.supervisor.size() <= 120
      && data.studentName is string
      && data.studentName.size() >= 2
      && data.studentName.size() <= 120
      && data.fileUrl is string
      && data.fileUrl.size() > 10
      && data.filePublicId is string
      && data.filePublicId.size() > 0
      && data.status is string
      && isValidProjectStatus(data.status)
      && isValidEmbedding(data.embedding)
      && data.createdAt is string
      && data.updatedAt is string;
    }

    function isValidDepartmentRecord(data) {
      return data.keys().hasOnly([
        'name',
        'createdAt',
        'updatedAt',
        'createdByUid'
      ])
      && data.name is string
      && data.name.size() >= 2
      && data.name.size() <= 120
      && data.createdAt is string
      && data.updatedAt is string
      && data.createdByUid is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isSupervisor();
      allow list: if isSignedIn();

      allow create: if isOwner(userId)
        && isValidUserProfile(request.resource.data, userId)
        && hasClearanceShape(request.resource.data)
        && (
          !(request.auth.token.email is string)
          || request.resource.data.email == request.auth.token.email
        )
        && request.resource.data.role in ['student', 'supervisor']
        && (
          request.resource.data.role != 'student'
          || (
            request.resource.data.uploadCleared == false
            && request.resource.data.clearedBySupervisorUid == ''
            && request.resource.data.clearedBySupervisorName == ''
          )
        );

      allow update: if (
        isOwner(userId)
        && isValidUserProfile(request.resource.data, userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.uploadCleared == resource.data.uploadCleared
        && request.resource.data.clearedBySupervisorUid == resource.data.clearedBySupervisorUid
        && request.resource.data.clearedBySupervisorName == resource.data.clearedBySupervisorName
        && request.resource.data.clearanceUpdatedAt == resource.data.clearanceUpdatedAt
        && request.resource.data.createdAt == resource.data.createdAt
      ) || (
        isAdmin()
        && isValidUserProfile(request.resource.data, userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
      ) || canSupervisorUpdateStudentClearance();

      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if isSignedIn();

      allow create: if (isAdmin() || isSupervisor() || isClearedStudent())
        && isValidProjectRecord(request.resource.data);

      allow update: if (isAdmin() || isSupervisor())
        && isValidProjectRecord(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isAdmin() || isSupervisor();
    }

    match /departments/{departmentId} {
      allow get, list: if true;

      allow create: if isAdmin()
        && isValidDepartmentRecord(request.resource.data);

      allow update: if isAdmin()
        && isValidDepartmentRecord(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdByUid == resource.data.createdByUid;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
