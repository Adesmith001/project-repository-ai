rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function requesterDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function requesterProfileExists() {
      return isSignedIn() && requesterDoc().data != null;
    }

    function supervisorDoc(supervisorUid) {
      return get(/databases/$(database)/documents/users/$(supervisorUid));
    }

    function isAdmin() {
      return requesterProfileExists() && requesterDoc().data.role == 'admin';
    }

    function isSupervisor() {
      return requesterProfileExists() && requesterDoc().data.role == 'supervisor';
    }

    function isClearedStudent() {
      return requesterProfileExists()
        && requesterDoc().data.role == 'student'
        && ("uploadCleared" in requesterDoc().data)
        && requesterDoc().data.uploadCleared == true;
    }

    function isValidRole(role) {
      return role in ['student', 'supervisor', 'admin'];
    }

    function isValidProjectStatus(status) {
      return status in ['approved', 'pending', 'rejected'];
    }

    function hasClearanceShape(data) {
      return data.uploadCleared is bool
      && data.clearedBySupervisorUid is string
      && data.clearedBySupervisorName is string
      && data.clearanceUpdatedAt is string;
    }

    function hasSupervisorAssignmentShape(data) {
      return data.assignedSupervisorUid is string
      && data.assignedSupervisorName is string;
    }

    function hasOptionalSupervisorAssignmentShape(data) {
      return (
        !('assignedSupervisorUid' in data)
        && !('assignedSupervisorName' in data)
      ) || hasSupervisorAssignmentShape(data);
    }

    function hasValidSupervisorAssignment(data) {
      return !('assignedSupervisorUid' in data)
      || (
        hasSupervisorAssignmentShape(data)
        && (
          (data.role == 'student'
            && (
              (data.assignedSupervisorUid.size() > 0
                && data.assignedSupervisorName.size() >= 2
                && supervisorDoc(data.assignedSupervisorUid).data != null
                && supervisorDoc(data.assignedSupervisorUid).data.role == 'supervisor'
                && supervisorDoc(data.assignedSupervisorUid).data.fullName == data.assignedSupervisorName)
              || (isAdmin()
                && data.assignedSupervisorUid == ''
                && data.assignedSupervisorName == '')
            ))
          || (data.role != 'student'
            && data.assignedSupervisorUid == ''
            && data.assignedSupervisorName == '')
        )
      );
    }

    function isValidUserProfile(data, userId) {
      return data.keys().hasOnly([
        'uid',
        'email',
        'fullName',
        'photoURL',
        'department',
        'role',
        'assignedSupervisorUid',
        'assignedSupervisorName',
        'uploadCleared',
        'clearedBySupervisorUid',
        'clearedBySupervisorName',
        'clearanceUpdatedAt',
        'createdAt',
        'updatedAt'
      ])
      && data.uid is string
      && data.uid == userId
      && data.email is string
      && data.email.size() > 3
      && data.fullName is string
      && data.fullName.size() >= 2
      && data.fullName.size() <= 120
      && (!("photoURL" in data) || data.photoURL is string)
      && data.department is string
      && data.department.size() >= 2
      && data.department.size() <= 120
      && data.role is string
      && isValidRole(data.role)
      && hasOptionalSupervisorAssignmentShape(data)
      && hasValidSupervisorAssignment(data)
      && (
        (
          !("uploadCleared" in data)
          && !("clearedBySupervisorUid" in data)
          && !("clearedBySupervisorName" in data)
          && !("clearanceUpdatedAt" in data)
        )
        || hasClearanceShape(data)
      )
      && data.createdAt is string
      && data.updatedAt is string;
    }

    function canSupervisorUpdateStudentClearance() {
      return isSupervisor()
      && resource.data.role == 'student'
      && ('assignedSupervisorUid' in resource.data)
      && resource.data.assignedSupervisorUid == request.auth.uid
      && request.resource.data.role == 'student'
      && request.resource.data.uid == resource.data.uid
      && request.resource.data.email == resource.data.email
      && request.resource.data.fullName == resource.data.fullName
      && request.resource.data.department == resource.data.department
      && request.resource.data.photoURL == resource.data.photoURL
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'uploadCleared',
        'clearedBySupervisorUid',
        'clearedBySupervisorName',
        'clearanceUpdatedAt',
        'updatedAt'
      ])
      && (
        (request.resource.data.uploadCleared == true
          && request.resource.data.clearedBySupervisorUid == request.auth.uid
          && request.resource.data.clearedBySupervisorName.size() >= 2)
        || (request.resource.data.uploadCleared == false
          && request.resource.data.clearedBySupervisorUid == ''
          && request.resource.data.clearedBySupervisorName == '')
      );
    }

    function canOwnerSetInitialSupervisorAssignment(userId) {
      return isOwner(userId)
      && resource.data.role == 'student'
      && request.resource.data.role == 'student'
      && (
        !('assignedSupervisorUid' in resource.data)
        || resource.data.assignedSupervisorUid == ''
      )
      && request.resource.data.assignedSupervisorUid is string
      && request.resource.data.assignedSupervisorUid.size() > 0
      && request.resource.data.assignedSupervisorName is string
      && request.resource.data.assignedSupervisorName.size() >= 2
      && supervisorDoc(request.resource.data.assignedSupervisorUid).data != null
      && supervisorDoc(request.resource.data.assignedSupervisorUid).data.role == 'supervisor'
      && supervisorDoc(request.resource.data.assignedSupervisorUid).data.fullName == request.resource.data.assignedSupervisorName
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'assignedSupervisorUid',
        'assignedSupervisorName',
        'updatedAt'
      ]);
    }

    function isValidKeywords(keywords) {
      return keywords is list
      && keywords.size() > 0
      && keywords.size() <= 20
      && keywords[0] is string;
    }

    function isValidEmbedding(embedding) {
      return embedding is list
      && embedding.size() > 0
      && embedding.size() <= 4096
      && embedding[0] is number;
    }

    function isValidProjectRecord(data) {
      return data.keys().hasOnly([
        'title',
        'abstract',
        'keywords',
        'department',
        'year',
        'supervisor',
        'supervisorUid',
        'studentName',
        'studentUid',
        'fileUrl',
        'filePublicId',
        'status',
        'rejectionReason',
        'embedding',
        'createdAt',
        'updatedAt'
      ])
      && data.title is string
      && data.title.size() >= 5
      && data.title.size() <= 300
      && data.abstract is string
      && data.abstract.size() >= 20
      && data.abstract.size() <= 20000
      && isValidKeywords(data.keywords)
      && data.department is string
      && data.department.size() >= 2
      && data.department.size() <= 120
      && data.year is int
      && data.year >= 2000
      && data.year <= 2100
      && data.supervisor is string
      && data.supervisor.size() >= 2
      && data.supervisor.size() <= 120
      && (
        !('supervisorUid' in data)
        || data.supervisorUid is string
      )
      && data.studentName is string
      && data.studentName.size() >= 2
      && data.studentName.size() <= 120
      && (
        !('studentUid' in data)
        || data.studentUid is string
      )
      && data.fileUrl is string
      && data.fileUrl.size() > 10
      && data.filePublicId is string
      && data.filePublicId.size() > 0
      && data.status is string
      && isValidProjectStatus(data.status)
      && data.rejectionReason is string
      && data.rejectionReason.size() <= 2000
      && (
        (data.status == 'rejected' && data.rejectionReason.size() >= 10)
        || (data.status != 'rejected' && data.rejectionReason == '')
      )
      && isValidEmbedding(data.embedding)
      && data.createdAt is string
      && data.updatedAt is string;
    }

    function canStudentCreateAssignedProject(data) {
      return isClearedStudent()
      && data.studentUid is string
      && data.studentUid == request.auth.uid
      && data.supervisorUid is string
      && data.supervisorUid.size() > 0
      && data.supervisorUid == requesterDoc().data.assignedSupervisorUid
      && data.supervisor == requesterDoc().data.assignedSupervisorName
      && data.studentName == requesterDoc().data.fullName
      && data.rejectionReason == ''
      && data.status == 'pending';
    }

    function isSupervisorAssignedToProject(project) {
      return isSupervisor()
      && (
        (('supervisorUid' in project)
          && project.supervisorUid is string
          && project.supervisorUid == request.auth.uid)
        || (project.supervisor is string
          && project.supervisor == requesterDoc().data.fullName)
      );
    }

    function canSupervisorReviewProject() {
      return isSupervisorAssignedToProject(resource.data)
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'status',
        'rejectionReason',
        'updatedAt'
      ])
      && isValidProjectStatus(request.resource.data.status)
      && (
        (request.resource.data.status == 'rejected' && request.resource.data.rejectionReason.size() >= 10)
        || (request.resource.data.status != 'rejected' && request.resource.data.rejectionReason == '')
      )
      && request.resource.data.createdAt == resource.data.createdAt;
    }

    function canStudentDeleteRejectedOwnProject() {
      return requesterProfileExists()
      && requesterDoc().data.role == 'student'
      && resource.data.studentUid is string
      && resource.data.studentUid == request.auth.uid
      && resource.data.status == 'rejected';
    }

    function isValidDepartmentRecord(data) {
      return data.keys().hasOnly([
        'name',
        'createdAt',
        'updatedAt',
        'createdByUid'
      ])
      && data.name is string
      && data.name.size() >= 2
      && data.name.size() <= 120
      && data.createdAt is string
      && data.updatedAt is string
      && data.createdByUid is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isSupervisor();
      allow list: if isSignedIn();

      allow create: if isOwner(userId)
        && isValidUserProfile(request.resource.data, userId)
        && hasSupervisorAssignmentShape(request.resource.data)
        && hasClearanceShape(request.resource.data)
        && (
          !(request.auth.token.email is string)
          || request.resource.data.email == request.auth.token.email
        )
        && request.resource.data.role in ['student', 'supervisor']
        && (
          request.resource.data.role != 'student'
          || (
            request.resource.data.assignedSupervisorUid.size() > 0
            && request.resource.data.assignedSupervisorName.size() >= 2
            && request.resource.data.uploadCleared == false
            && request.resource.data.clearedBySupervisorUid == ''
            && request.resource.data.clearedBySupervisorName == ''
          )
        )
        && (
          request.resource.data.role != 'supervisor'
          || (
            request.resource.data.assignedSupervisorUid == ''
            && request.resource.data.assignedSupervisorName == ''
          )
        );

      allow update: if (
        isOwner(userId)
        && isValidUserProfile(request.resource.data, userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.assignedSupervisorUid == resource.data.assignedSupervisorUid
        && request.resource.data.assignedSupervisorName == resource.data.assignedSupervisorName
        && request.resource.data.uploadCleared == resource.data.uploadCleared
        && request.resource.data.clearedBySupervisorUid == resource.data.clearedBySupervisorUid
        && request.resource.data.clearedBySupervisorName == resource.data.clearedBySupervisorName
        && request.resource.data.clearanceUpdatedAt == resource.data.clearanceUpdatedAt
        && request.resource.data.createdAt == resource.data.createdAt
      ) || canOwnerSetInitialSupervisorAssignment(userId) || (
        isAdmin()
        && isValidUserProfile(request.resource.data, userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
      ) || (
        canSupervisorUpdateStudentClearance()
      );

      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if isSignedIn();

      allow create: if (
        (isAdmin() || isSupervisor())
        && isValidProjectRecord(request.resource.data)
      ) || (
        canStudentCreateAssignedProject(request.resource.data)
        && isValidProjectRecord(request.resource.data)
      );

      allow update: if isAdmin()
        && isValidProjectRecord(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
      || canSupervisorReviewProject();

      allow delete: if isAdmin() || canStudentDeleteRejectedOwnProject();
    }

    match /departments/{departmentId} {
      allow get, list: if true;

      allow create: if isAdmin()
        && isValidDepartmentRecord(request.resource.data);

      allow update: if isAdmin()
        && isValidDepartmentRecord(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdByUid == resource.data.createdByUid;

      allow delete: if isAdmin();
    }

    match /users/{userId}/topicCheckSessions/{sessionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
